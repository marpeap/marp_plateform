// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  CLIENT
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ArticleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectCategory {
  BOTS
  IA
  GODOT
  WEB
  SCRAPING
  AUTOMATION
  CRYPTO
}

enum MediaCategory {
  PROJETS
  FORMATIONS
  UI
  LOGOS
}

model User {
  id            String          @id @default(cuid())
  name          String?
  email         String?         @unique
  image         String?
  role          Role            @default(EDITOR)
  accounts      Account[]
  sessions      Session[]
  projects      Project[]       @relation("OwnerProjects")
  clientRecords ClientProject[] @relation("ClientUser")
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Project {
  id          String         @id @default(cuid())
  title       String
  slug        String         @unique
  description String
  category    ProjectCategory
  stack       String[]
  difficulty  String?
  role        String?
  repoUrl     String?
  demoUrl     String?
  status      ProjectStatus  @default(DRAFT)
  private     Boolean        @default(false)
  featured    Boolean        @default(false)
  authorId    String?
  author      User?          @relation("OwnerProjects", fields: [authorId], references: [id])
  media       Media[]
  clientLinks ClientProject[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
}

model Article {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  excerpt     String?
  content     String
  status      ArticleStatus @default(DRAFT)
  tags        String[]
  media       Media[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Page {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  content   String
  metaTitle String?
  metaDesc  String?
  media     Media[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id          String        @id @default(cuid())
  url         String
  alt         String?
  category    MediaCategory?
  projectId   String?
  articleId   String?
  pageId      String?
  mimeType    String?
  size        Int?
  createdAt   DateTime      @default(now())
  project     Project?      @relation(fields: [projectId], references: [id])
  article     Article?      @relation(fields: [articleId], references: [id])
  page        Page?         @relation(fields: [pageId], references: [id])
}

model Contact {
  id        String   @id @default(cuid())
  email     String
  name      String
  message   String
  createdAt DateTime @default(now())
  status    String   @default("new")
}

model ClientProject {
  id           String   @id @default(cuid())
  clientId     String
  projectId    String
  title        String
  status       String   @default("en cours")
  deliverables String[]
  documents    String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client User    @relation("ClientUser", fields: [clientId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
}
